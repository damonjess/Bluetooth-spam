<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/setTxPowerDialogTxPowerTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/power_level_high"
        android:textColor="?attr/colorOnSurface"
        android:textSize="16sp"
        android:textStyle="bold" />

    <com.google.android.material.slider.Slider
        android:id="@+id/setTxPowerDialogSeekbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:valueFrom="0.0"
        android:valueTo="3.0"
        android:stepSize="1.0"
        android:value="3.0"
        app:thumbColor="?attr/colorPrimary"
        app:trackColorActive="?attr/colorPrimary"
        app:trackColorInactive="?attr/colorOutline" />

</LinearLayout>
